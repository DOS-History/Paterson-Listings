0814 04 08                 1053 	ADD	AL,8		;Storage needed for the node
0816 8B 1E CE 1B           1054 	MOV	BX,[HEAP]
081A 8A D0                 1055 	MOV	DL,AL
081C B6 00                 1056 	MOV	DH,0
081E 2B DA                 1057 	SUB	BX,DX		;Heap grows downward
0820 89 1E CE 1B           1058 	MOV	[HEAP],BX
