0171 0D 0A 0D 0A 24        0069 	DB	13,10,13,10,'$'
0176                       0070 
0176                       0071 BEGIN:
0176 BC A6 2A              0072 	MOV	SP,STACK
0179 BA 02 01              0073 	MOV	DX,HEADER
017C B4 09                 0074 	MOV	AH,PRINTMES
017E CD 21                 0075 	INT	33
0180 A0 6D 00              0076 	MOV	AL,[FCB+17]
0183 A2 35 21              0077 	MOV	[SYMFLG],AL	;Save symbol table request flag
0186 BE 65 00              0078 	MOV	SI,FCB+9	;Point to file extension
0189 AC                    0079 	LODB			;Get source drive letter
018A E8 13 01              0080 	CALL	CHKDSK		;Valid drive?
018D 0A C0                 0081 	OR	AL,AL
018F 74 03                 0082 	JZ	DEFAULT		;If no extension, use existing drive spec
0191 A2 5C 00              0083 	MOV	[FCB],AL
0194                       0084 DEFAULT:
0194 AC                    0085 	LODB			;Get HEX file drive letter
