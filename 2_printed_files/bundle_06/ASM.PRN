049E 33 D2                 0529 	XOR	DX,DX		;Initial value
04A0 3C 2B                 0530 	CMP	AL,'+'
04A2 74 0C                 0531 	JZ	PLSMNS
04A4 3C 2D                 0532 	CMP	AL,'-'
04A6 74 08                 0533 	JZ	PLSMNS
