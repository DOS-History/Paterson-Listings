0197 74 03                 0087 	JZ	L0000
0199 E8 04 01              0088 	CALL	CHKDSK
019C                       0089 L0000:	
019C A2 80 20              0090 	MOV	[HEXFCB],AL
019F AC                    0091 	LODB			;Get PRN file drive letter
01A0 B4 00                 0092 	MOV	AH,0		;Signal no PRN file
01A2 3C 5A                 0093 	CMP	AL,'Z'		;Suppress PRN file?
01A4 74 15                 0094 	JZ	NOPRN
