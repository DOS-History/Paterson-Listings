39800           CALL    $SCALXY                 ;check for point on screen
39900           JNC     CIR_P_FIN               ;off screen, ignore
40000           PUSH    BP
40100           PUSH    DI                      ;save X,Y
40200           CALL    $DRAW_LINE              ;draw line from point to center
